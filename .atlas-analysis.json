  "keyFeatures": [
    "Bytecode VM with stack-based execution",
    "Optional JIT compilation via Cranelift",
    "Mark-and-sweep garbage collector",
    "First-class functions and closures",
    "Structs with static methods",
    "Comprehensive standard library (I/O, system, math)",
    "Interactive REPL and debugger",
    "Language Server Protocol (LSP) support",
    "Tail call optimization",
    "Format strings (f-strings)"
  ],
  "publicApiSurface": [
    "walrus <file.walrus> - Execute a Walrus script",
    "walrus - Start interactive REPL",
    "walrus -c <file.walrus> - Compile to bytecode and run in VM",
    "walrus --disassemble <file.walrus> - Show bytecode disassembly",
    "walrus --debugger <file.walrus> - Start interactive debugger",
    "walrus --jit <file.walrus> - Enable JIT compilation",
    "walrus --jit-stats <file.walrus> - Show JIT profiling statistics",
    "len(x) - Get length of collection",
    "str(x) - Convert value to string",
    "type(x) - Get type name",
    "input(prompt) - Read user input",
    "__gc__() - Trigger garbage collection",
    "__heap_stats__() - Get heap statistics",
    "import \"std/io\" - File I/O operations",
    "import \"std/sys\" - System operations",
    "import \"std/math\" - Math and random utilities"
  ]
